# AI下注王默认参赛选手：
# 1 Gemini / 2 GPT / 3 Claude 走 WeGame LLM：使用 LLM_API_KEY + LLM_BASE_URL
# 4 Hy3 / 5 Kimi / 6 MiniMax / 7 DeepSeek Flash / 8 DeepSeek Pro 走腾讯云 TokenHub：使用 TOKENHUB_API_KEY
# 如需完全自定义阵容，可设置 AI_CONTEST_MODELS 覆盖默认逻辑。
# AI_CONTEST_MODELS='[{"id":"wegame-gemini","name":"Gemini","provider":"WeGame LLM","baseUrl":"https://llm-api-na.wegame.com.cn","apiKeyEnv":"LLM_API_KEY","model":"gemini-3.1-pro-preview"}]'

